#!/bin/bash
#
# PGit Pre-commit Hook
# 
# This hook checks for statistical drift in tracked datasets before allowing a commit.
# If p < 0.05 (significant drift detected), the commit is blocked.
#
# Installation:
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#

set -e

# Source cargo environment if available
if [ -f "$HOME/.cargo/env" ]; then
    . "$HOME/.cargo/env"
fi

# Configuration
PGIT_THRESHOLD="${PGIT_THRESHOLD:-0.05}"
PGIT_CONFIG_FILE=".pgit-config"
PGIT_BINARY="${PGIT_BINARY:-pgit}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 PGit Pre-commit Hook"
echo "======================="

# Check if .pgit directory exists
if [ ! -d ".pgit" ]; then
    echo -e "${YELLOW}⚠️  No .pgit directory found. Skipping statistical checks.${NC}"
    exit 0
fi

# Check if pgit binary is available
if ! command -v "$PGIT_BINARY" &> /dev/null; then
    echo -e "${YELLOW}⚠️  pgit binary not found in PATH. Skipping statistical checks.${NC}"
    echo "   Hint: Add pgit to your PATH or set PGIT_BINARY environment variable"
    exit 0
fi

# Check for config file
if [ -f "$PGIT_CONFIG_FILE" ]; then
    echo "📋 Reading tracked datasets from $PGIT_CONFIG_FILE"
    
    DRIFT_DETECTED=0
    
    while IFS='=' read -r dataset_name file_path; do
        # Skip empty lines and comments
        [[ -z "$dataset_name" || "$dataset_name" =~ ^# ]] && continue
        
        # Trim whitespace
        dataset_name=$(echo "$dataset_name" | xargs)
        file_path=$(echo "$file_path" | xargs)
        
        # Check if file exists
        if [ ! -f "$file_path" ]; then
            echo -e "${YELLOW}⚠️  File not found: $file_path${NC}"
            continue
        fi
        
        echo ""
        echo "Checking: $dataset_name ($file_path)"
        echo "----------------------------------------"
        
        # Run pgit check
        if ! $PGIT_BINARY check "$file_path" "$dataset_name" --threshold "$PGIT_THRESHOLD"; then
            DRIFT_DETECTED=1
        fi
    done < "$PGIT_CONFIG_FILE"
    
    echo ""
    echo "======================="
    
    if [ $DRIFT_DETECTED -eq 1 ]; then
        echo -e "${RED}❌ COMMIT BLOCKED: Statistical drift detected${NC}"
        echo ""
        echo "Your data has changed significantly (p < $PGIT_THRESHOLD)."
        echo "This may indicate:"
        echo "  • Data pipeline changes"
        echo "  • Distribution shift in production"
        echo "  • Feature engineering updates"
        echo ""
        echo "To proceed anyway:"
        echo "  • Commit with --no-verify to bypass this hook"
        echo "  • Or update your baseline: pgit commit <file> <name> -m 'Update baseline'"
        exit 1
    else
        echo -e "${GREEN}✅ All checks passed. No significant drift detected.${NC}"
        exit 0
    fi
else
    echo -e "${YELLOW}⚠️  No .pgit-config file found. Skipping statistical checks.${NC}"
    echo "   Create a .pgit-config file with your tracked datasets:"
    echo "   dataset_name=/path/to/data.csv"
    exit 0
fi
